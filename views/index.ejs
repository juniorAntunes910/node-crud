<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Crud</title>
</head>

<body>
    <h1>Lista Prod</h1>

    <table border="1">
        <thead>
            <tr>
                <th>
                    ID
                </th>
                <th>
                    Nome
                </th>
                <th>
                    Preço
                </th>
                <th>
                    Ações
                </th>
            </tr>
        </thead>
        <tbody>
            <% listaProdutos.forEach(produto => { %>
                <tr>
                    <td>
                        <%= produto.id %>
                    </td>
                    <td>
                        <%= produto.nome %>
                    </td>
                    <td>
                        <%= produto.preco %>
                    </td>
                    <td>
                        <a href="/editar/<%= produto.id %>">Editar</a>
                        <button>Deletar</button>
                    </td>
                </tr>
           <% }) %>
        </tbody>
    </table>

    <a href="/cadastrar">Cadastrar novo produto </a>
</body>

</html>
